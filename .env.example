# Strava API credentials — copy this file to `.env` and fill in your values.
# Create an app at https://www.strava.com/settings/api
# Set the app's "Authorization Callback Domain" to: localhost
#
# `.env` is gitignored — never commit your real client secret.

STRAVA_CLIENT_ID=your_client_id_here
STRAVA_CLIENT_SECRET=your_client_secret_here
